---
import Base from '../../layouts/Base.astro';
import { withBase } from '../../utils/paths';

const artworks = [
  {
    id: 1,
    title: "Manjushri of the Flaming Sword",
    artist: "Tenzin Norbu",
    category: "Thangka",
    tag: "tag-thangka",
    image: "https://images.unsplash.com/photo-1578662996442-48f60103fc96?w=600&auto=format&fit=crop&q=80",
    alt: "Thangka painting of Manjushri deity in gold and vermillion on dark ground"
  },
  {
    id: 2,
    title: "Wheel of Life",
    artist: "Dechen Wangmo",
    category: "Thangka",
    tag: "tag-thangka",
    image: "https://images.unsplash.com/photo-1547638375-ebf04735d792?w=600&auto=format&fit=crop&q=80",
    alt: "Detailed Bhavachakra wheel of life thangka painting"
  },
  {
    id: 3,
    title: "Thousand-Armed Chenrezig",
    artist: "Lobsang Dakpa",
    category: "Thangka",
    tag: "tag-thangka",
    image: "https://images.unsplash.com/photo-1617791160588-241658ad5fda?w=600&auto=format&fit=crop&q=80",
    alt: "Large format thangka painting of Avalokitesvara with many arms"
  },
  {
    id: 4,
    title: "Dancing Mahakala",
    artist: "Karma Yangchen",
    category: "Thangka",
    tag: "tag-thangka",
    image: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&auto=format&fit=crop&q=80",
    alt: "Dark-ground thangka of protective deity Mahakala in dynamic dance pose"
  },
  {
    id: 5,
    title: "Bronze Tara — Seated",
    artist: "Sonam Rinchen",
    category: "Sculpture",
    tag: "tag-sculpture",
    image: "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600&auto=format&fit=crop&q=80",
    alt: "Gilded bronze sculpture of seated Green Tara bodhisattva"
  },
  {
    id: 6,
    title: "Dorje Chang in Repose",
    artist: "Sonam Rinchen",
    category: "Sculpture",
    tag: "tag-sculpture",
    image: "https://images.unsplash.com/photo-1578321272176-b7bbc0679853?w=600&auto=format&fit=crop&q=80",
    alt: "Bronze sculpture of Vajradhara seated in meditation posture"
  },
  {
    id: 7,
    title: "Serpent Dragon Khata",
    artist: "Pema Dolkar",
    category: "Textile",
    tag: "tag-textile",
    image: "https://images.unsplash.com/photo-1594736797933-d0501ba2fe65?w=600&auto=format&fit=crop&q=80",
    alt: "Ceremonial khata textile with woven dragon and cloud motifs"
  },
  {
    id: 8,
    title: "Sacred Prayer Brocade",
    artist: "Pema Dolkar",
    category: "Textile",
    tag: "tag-textile",
    image: "https://images.unsplash.com/photo-1558769132-cb1aea458c5e?w=600&auto=format&fit=crop&q=80",
    alt: "Rich silk brocade textile panel with interlocking lotus motifs"
  },
  {
    id: 9,
    title: "Uchen Script — Heart Sutra",
    artist: "Rigzin Choedon",
    category: "Calligraphy",
    tag: "tag-calligraphy",
    image: "https://images.unsplash.com/photo-1586953208448-b95a79798f07?w=600&auto=format&fit=crop&q=80",
    alt: "Tibetan Uchen calligraphy of the Heart Sutra on handmade lokta paper"
  },
  {
    id: 10,
    title: "The Eight Auspicious Symbols",
    artist: "Rigzin Choedon",
    category: "Calligraphy",
    tag: "tag-calligraphy",
    image: "https://images.unsplash.com/photo-1541753866388-0b3c701627d3?w=600&auto=format&fit=crop&q=80",
    alt: "Decorative calligraphic rendering of Ashtamangala symbols"
  },
  {
    id: 11,
    title: "Kalachakra Mandala",
    artist: "Tenzin Norbu",
    category: "Thangka",
    tag: "tag-thangka",
    image: "https://images.unsplash.com/photo-1626544827763-d516dce335e2?w=600&auto=format&fit=crop&q=80",
    alt: "Intricate Kalachakra mandala thangka in mineral pigments and gold"
  },
  {
    id: 12,
    title: "Appliqué Amitabha",
    artist: "Pema Dolkar",
    category: "Textile",
    tag: "tag-textile",
    image: "https://images.unsplash.com/photo-1502602898657-3e91760cbb34?w=600&auto=format&fit=crop&q=80",
    alt: "Silk appliqué thangka depicting Amitabha Buddha in pure land setting"
  }
];

const categories = ["All", "Thangka", "Sculpture", "Textile", "Calligraphy"];
---

<Base
  title="Gallery"
  description="Explore the Vermillion Arts gallery — thangka paintings, Buddhist sculpture, Tibetan textiles, and calligraphy by our master artists in Dharamsala."
>

  <!-- Page Hero -->
  <section class="page-hero" aria-label="Gallery page header">
    <div class="page-hero-ornament" aria-hidden="true"></div>
    <div class="container">
      <p class="page-hero-eyebrow">Our Collection</p>
      <h1 class="page-hero-title">The Gallery</h1>
      <p class="page-hero-desc">
        Works by our resident and visiting artists — sacred paintings, sculpture,
        textiles, and calligraphy created in the living tradition of Tibetan art.
      </p>
    </div>
  </section>


  <!-- Gallery -->
  <section class="section" aria-labelledby="gallery-heading">
    <div class="container">

      <h2 class="visually-hidden" id="gallery-heading">Artwork Gallery</h2>

      <!-- Filter tabs (decorative, not functional JS) -->
      <nav class="gallery-filter-tabs" aria-label="Filter artwork by category">
        {categories.map((cat, i) => (
          <span class={`gallery-tab${i === 0 ? ' active' : ''}`} role="button" tabindex="0">
            {cat}
          </span>
        ))}
      </nav>

      <!-- Gallery grid -->
      <div class="gallery-grid" role="list" aria-label="Artwork grid">
        {artworks.map(work => (
          <article class="gallery-item" role="listitem">
            <img
              class="gallery-item-image"
              src={work.image}
              alt={work.alt}
              loading="lazy"
              width="600"
              height="600"
            />
            <div class="gallery-item-overlay" aria-hidden="true"></div>
            <div class="gallery-item-info">
              <p class="gallery-item-category">
                <span class={`tag-badge ${work.tag}`}>{work.category}</span>
              </p>
              <h3 class="gallery-item-title">{work.title}</h3>
              <p class="gallery-item-artist">{work.artist}</p>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>


  <!-- Commission CTA -->
  <section class="section-sm" style="background: var(--ivory);" aria-label="Commission artwork">
    <div class="container">
      <div style="display:flex; align-items:center; justify-content:space-between; gap:var(--space-xl); flex-wrap:wrap;">
        <div>
          <h2 class="text-h2" style="margin-bottom:var(--space-sm);">Commission an Original Work</h2>
          <p class="text-lead" style="max-width:50ch;">
            Our artists accept commissions for thangkas, sculptures, and textile pieces.
            Each commission is a sacred undertaking, created with care and intention.
          </p>
        </div>
        <a href={withBase('/contact/')} class="btn btn-primary btn-lg">Enquire About a Commission</a>
      </div>
    </div>
  </section>

</Base>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
  }
</style>
