---
import Base from '../../layouts/Base.astro';
import { withBase } from '../../utils/paths';
---

<Base
  title="Contact"
  description="Contact Vermillion Arts in Dharamsala — class enrolment, gallery enquiries, commissions, and visiting information. Find us on Jogiwara Road, McLeod Ganj."
>

  <!-- Page Hero -->
  <section class="page-hero" aria-label="Contact page header">
    <div class="page-hero-ornament" aria-hidden="true"></div>
    <div class="container">
      <p class="page-hero-eyebrow">Get in Touch</p>
      <h1 class="page-hero-title">Contact Us</h1>
      <p class="page-hero-desc">
        We welcome enquiries about classes, commissions, gallery visits, residencies,
        and general information about Tibetan arts. We aim to reply within two working days.
      </p>
    </div>
  </section>


  <!-- Contact main -->
  <section class="section" aria-labelledby="contact-heading">
    <div class="container">
      <h2 class="visually-hidden" id="contact-heading">Contact Information and Form</h2>

      <div class="contact-grid">

        <!-- Left: info -->
        <aside>

          <div class="contact-info-block">
            <h3 class="contact-info-title">Address</h3>
            <p class="contact-info-text">
              Vermillion Arts<br />
              Jogiwara Road<br />
              McLeod Ganj, Dharamsala 176219<br />
              Himachal Pradesh, India
            </p>
          </div>

          <div class="contact-info-block">
            <h3 class="contact-info-title">Phone & Email</h3>
            <p class="contact-info-text">
              Phone: <a href="tel:+911892221345">+91 1892 221345</a><br />
              WhatsApp: <a href="https://wa.me/911892221345" target="_blank" rel="noopener noreferrer">+91 1892 221345</a><br />
              Email: <a href="mailto:hello@vermillionarts.org">hello@vermillionarts.org</a>
            </p>
          </div>

          <div class="contact-info-block">
            <h3 class="contact-info-title">Opening Hours</h3>
            <table class="hours-table">
              <tbody>
                <tr>
                  <td>Monday</td>
                  <td>9:00am – 6:00pm</td>
                </tr>
                <tr>
                  <td>Tuesday</td>
                  <td>9:00am – 6:00pm</td>
                </tr>
                <tr>
                  <td>Wednesday</td>
                  <td>9:00am – 6:00pm</td>
                </tr>
                <tr>
                  <td>Thursday</td>
                  <td>9:00am – 8:00pm</td>
                </tr>
                <tr>
                  <td>Friday</td>
                  <td>9:00am – 6:00pm</td>
                </tr>
                <tr>
                  <td>Saturday</td>
                  <td>10:00am – 5:00pm<br /><small>(Open Studio day)</small></td>
                </tr>
                <tr>
                  <td>Sunday</td>
                  <td>Closed</td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="contact-info-block">
            <h3 class="contact-info-title">Getting Here</h3>
            <p class="contact-info-text">
              We are a 10-minute walk from the main McLeod Ganj bus stand.
              From the square, walk down Jogiwara Road past the Tibetan Welfare Office —
              look for the vermillion red door on your left. Taxis are readily available
              from Dharamsala town (approximately ₹200–250).
            </p>
          </div>

        </aside>

        <!-- Right: contact -->
        <div>
          <div style="background:var(--ivory);border:1px solid var(--color-border);border-radius:12px;padding:2.5rem;">
            <h3 style="color:var(--vermillion);font-size:1.3rem;margin-bottom:1rem;">Send a Message</h3>
            <p style="color:var(--color-muted, #666);line-height:1.8;margin-bottom:1.5rem;">
              For class enquiries, gallery visits, commission requests, and residency applications, please email us directly. We aim to reply within two working days.
            </p>
            <a href="mailto:hello@vermillion-arts.org" class="btn btn-primary" style="display:inline-flex;align-items:center;gap:0.5rem;">
              hello@vermillion-arts.org
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- Map placeholder -->
  <section class="section-sm" aria-label="Location map">
    <div class="container">
      <div class="map-placeholder">
        <div class="map-pin">
          <div class="map-pin-icon" aria-hidden="true">📍</div>
          <p class="map-pin-label">
            Vermillion Arts<br />
            Jogiwara Road, McLeod Ganj<br />
            Dharamsala 176219, India
          </p>
        </div>
        <!-- Decorative grid lines to suggest a map -->
        <svg
          style="position:absolute;inset:0;width:100%;height:100%;opacity:0.08;"
          aria-hidden="true"
          preserveAspectRatio="none"
        >
          <defs>
            <pattern id="map-grid" width="40" height="40" patternUnits="userSpaceOnUse">
              <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#786A60" stroke-width="0.5"/>
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#map-grid)" />
        </svg>
      </div>
    </div>
  </section>


  <!-- FAQ strip -->
  <section class="section-sm" style="background:var(--ivory);" aria-labelledby="faq-heading">
    <div class="container">
      <header class="section-header centered" style="margin-bottom:var(--space-xl);">
        <p class="section-eyebrow">Frequently Asked</p>
        <h2 class="section-title" id="faq-heading">Quick Answers</h2>
        <div class="section-divider"></div>
      </header>

      <div style="display:grid; grid-template-columns: repeat(2,1fr); gap:var(--space-xl); max-width:900px; margin:0 auto;">
        <div>
          <h3 class="text-h3" style="margin-bottom:var(--space-sm); font-size:1rem;">Do I need prior experience for the classes?</h3>
          <p style="font-size:0.9rem; line-height:1.7; color:var(--muted); max-width:none;">
            Most of our introductory courses require no prior art experience, only motivation and patience.
            The advanced thangka and gilding courses do require prior study; prerequisites are listed on each course page.
          </p>
        </div>
        <div>
          <h3 class="text-h3" style="margin-bottom:var(--space-sm); font-size:1rem;">Can I attend as a tourist visiting Dharamsala?</h3>
          <p style="font-size:0.9rem; line-height:1.7; color:var(--muted); max-width:none;">
            Absolutely. Our Saturday Open Studio days and single-day workshops are designed with visitors in mind.
            Contact us in advance to check availability, especially in peak season (March–June and September–November).
          </p>
        </div>
        <div>
          <h3 class="text-h3" style="margin-bottom:var(--space-sm); font-size:1rem;">Are artworks in the gallery for sale?</h3>
          <p style="font-size:0.9rem; line-height:1.7; color:var(--muted); max-width:none;">
            Selected works are available for purchase. Gallery pieces are priced from ₹8,000 for smaller studies
            to ₹3,50,000 for major works. Contact us by email for a current price list.
          </p>
        </div>
        <div>
          <h3 class="text-h3" style="margin-bottom:var(--space-sm); font-size:1rem;">Do you offer online classes?</h3>
          <p style="font-size:0.9rem; line-height:1.7; color:var(--muted); max-width:none;">
            We offer a limited number of online sessions for calligraphy and art history. Hands-on disciplines
            like thangka painting, sculpture, and weaving are best learned in person; we believe deeply in the
            student–teacher relationship as the core of transmission.
          </p>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
  }
  @media (max-width: 640px) {
    .faq-grid { grid-template-columns: 1fr !important; }
  }
</style>
