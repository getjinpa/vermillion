---
import Base from '../../layouts/Base.astro';
import { withBase } from '../../utils/paths';

const artists = [
  {
    name: "Tenzin Norbu",
    origin: "Lhasa, Tibet (born 1962)",
    specialty: "Thangka Painting",
    specialtyTag: "tag-thangka",
    role: "Founding Director & Senior Artist",
    image: "https://images.unsplash.com/photo-1463453091185-61582044d556?w=500&auto=format&fit=crop&q=80",
    alt: "Portrait of Tenzin Norbu, master thangka painter",
    bio: "Born into an artistic family in Lhasa, Tenzin Norbu trained from the age of nine under his uncle, the revered monk-painter Ngawang Dorje of his uncle's monastery. After arriving in Dharamsala in 1987, he spent a decade in contemplative study before co-founding Vermillion Arts in 2008. His thangkas in the Karma Gadri style have been exhibited in twelve countries and form part of permanent collections in international museum collections and cultural heritage foundations.",
    highlights: ["Karma Gadri lineage", "35+ years practice", "Thangka & gold work", "International exhibitions"]
  },
  {
    name: "Dechen Wangmo",
    origin: "Rebkong, Amdo (born 1978)",
    specialty: "Thangka Painting",
    specialtyTag: "tag-thangka",
    role: "Senior Artist",
    image: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=500&auto=format&fit=crop&q=80",
    alt: "Portrait of Dechen Wangmo, Rebkong tradition thangka artist",
    bio: "Dechen Wangmo is one of the very few women to hold full accreditation in the Rebkong thangka tradition — an art form historically practiced almost exclusively by men in Qinghai province. She trained under Master Tsering Norbu in Repkong for six years before moving to Dharamsala. Dechen is celebrated for her chromatic boldness and her complex mandala compositions, several of which have been commissioned by monasteries in France and the United States.",
    highlights: ["Rebkong school", "Mandala specialist", "Complex deity compositions", "Commissioned for monasteries"]
  },
  {
    name: "Sonam Rinchen",
    origin: "Kathmandu, Nepal (born 1971)",
    specialty: "Buddhist Sculpture",
    specialtyTag: "tag-sculpture",
    role: "Head of Sculpture",
    image: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=500&auto=format&fit=crop&q=80",
    alt: "Portrait of Sonam Rinchen, bronze sculptor",
    bio: "A master of the Newar tradition of lost-wax bronze casting, Sonam Rinchen apprenticed under the Shakya clan of Patan, Nepal — the community that has sustained this art form for over a millennium. He joined Vermillion Arts in 2010 and has since trained over sixty students in the full casting process. His sculptures range from intimate palm-sized devotional pieces to monumental works exceeding one metre, including a commissioned Maitreya for a monastery in Bordeaux.",
    highlights: ["Newar bronze tradition", "Lost-wax casting", "Iconometric precision", "Monumental commissions"]
  },
  {
    name: "Rigzin Choedon",
    origin: "Darjeeling (born 1985)",
    specialty: "Tibetan Calligraphy",
    specialtyTag: "tag-calligraphy",
    role: "Calligraphy & Paper Arts",
    image: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=500&auto=format&fit=crop&q=80",
    alt: "Portrait of Rigzin Choedon, Tibetan calligrapher",
    bio: "Rigzin Choedon began learning calligraphy at the Tibetan Children's Village school in Dharamsala and continued her studies under the late calligrapher Rinchen Tsewang in Darjeeling. She holds a master's degree in Tibetan literature from Rangjung Yeshe Institute in Kathmandu. At Vermillion Arts she teaches both the formal Uchen block script and the flowing Umé cursive style, as well as courses in the preparation of traditional lokta paper and handmade ink.",
    highlights: ["Uchen & Umé scripts", "Handmade paper", "Tibetan literature", "Sacred texts"]
  },
  {
    name: "Pema Dolkar",
    origin: "Shigatse, Tibet (born 1967)",
    specialty: "Textile Arts",
    specialtyTag: "tag-textile",
    role: "Head of Textile Arts",
    image: "https://images.unsplash.com/photo-1487412720507-e7ab37603c6f?w=500&auto=format&fit=crop&q=80",
    alt: "Portrait of Pema Dolkar, textile artist and weaver",
    bio: "Pema Dolkar is the acknowledged authority on Tibetan textile traditions within the Dharamsala exile community. Born in Shigatse to a family of weavers, she carries techniques learned from her mother and grandmother — women who had practiced continuously in Tibet before the upheaval of the 1950s. Pema is especially renowned for her appliqué thangkas, which take months of painstaking silk cutting and layering. Her work has been featured in exhibitions at leading international textile museums and the Himalayan Art Foundation.",
    highlights: ["Appliqué thangka", "Traditional weaving", "Natural dyeing", "Silk & brocade"]
  },
  {
    name: "Dr. Karma Phuntsok",
    origin: "Dharamsala (born 1969)",
    specialty: "Art History",
    specialtyTag: "tag-calligraphy",
    role: "Scholar in Residence",
    image: "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=500&auto=format&fit=crop&q=80",
    alt: "Portrait of Dr. Karma Phuntsok, Tibetan art historian",
    bio: "Dr. Karma Phuntsok holds a doctorate in Tibetan art history from a leading European university, where he wrote his dissertation on regional variations in early Guge-period painting. He serves as a senior researcher at the Central Tibetan Archives and lectures internationally on Himalayan iconography. At Vermillion Arts he teaches the popular Thursday evening course in Tibetan art history and iconography, and is available to consult on attribution and dating questions for collectors and curators.",
    highlights: ["European university doctorate", "Central Archives researcher", "Iconographic attribution", "Regional style analysis"]
  }
];
---

<Base
  title="Artists"
  description="Meet the master artists of Vermillion Arts — thangka painters, bronze sculptors, calligraphers, and textile artists preserving Tibetan art traditions in Dharamsala."
>

  <!-- Page Hero -->
  <section class="page-hero" aria-label="Artists page header">
    <div class="page-hero-ornament" aria-hidden="true"></div>
    <div class="container">
      <p class="page-hero-eyebrow">The People Behind the Work</p>
      <h1 class="page-hero-title">Our Artists</h1>
      <p class="page-hero-desc">
        Vermillion Arts is built around six extraordinary practitioners — each a
        guardian of a living tradition and a dedicated teacher sharing their
        knowledge with the next generation.
      </p>
    </div>
  </section>


  <!-- Artists Grid -->
  <section class="section" aria-labelledby="artists-heading">
    <div class="container">

      <h2 class="visually-hidden" id="artists-heading">Artist Profiles</h2>

      <div class="artists-grid">
        {artists.map(artist => (
          <article class="artist-card">
            <div class="artist-card-portrait">
              <img
                src={artist.image}
                alt={artist.alt}
                loading="lazy"
                width="500"
                height="375"
              />
              <span class={`artist-specialty-badge tag-badge ${artist.specialtyTag}`}>
                {artist.specialty}
              </span>
            </div>

            <div class="artist-card-body">
              <h3 class="artist-name">{artist.name}</h3>
              <p class="artist-origin">{artist.origin} · {artist.role}</p>
              <p class="artist-bio">{artist.bio}</p>
              <div class="artist-highlights">
                {artist.highlights.map(h => (
                  <span class="artist-tag">{h}</span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>


  <!-- Residency CTA -->
  <section class="section-sm" style="background: var(--midnight); color:#fff;" aria-label="Artist residency">
    <div class="container" style="text-align:center;">
      <p style="font-family:var(--font-ui); font-size:0.75rem; font-weight:700; letter-spacing:0.2em; text-transform:uppercase; color:var(--gold-light); margin-bottom:var(--space-md);">Open Call</p>
      <h2 class="text-h2" style="color:#fff; margin-bottom:var(--space-md);">Artist Residency Programme</h2>
      <p style="font-size:1.05rem; line-height:1.8; color:rgba(245,240,232,0.65); max-width:55ch; margin:0 auto var(--space-xl);">
        Each spring and autumn, Vermillion Arts invites two international artists for an eight-week residency.
        Residents work alongside our master artists, contribute to the public programme, and gain unparalleled
        access to living Tibetan art traditions.
      </p>
      <a href={withBase('/contact/')} class="btn btn-gold btn-lg">
        Apply for a Residency
      </a>
    </div>
  </section>

</Base>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
  }
</style>
